// secrets.h — копия для нового продукта.
//
// Скопируйте этот файл в каталог `include/` своего PlatformIO-проекта
// под именем `secrets.h` и пропишите свои значения. Файл `include/secrets.h`
// должен быть в `.gitignore`, чтобы credentials не попадали в репозиторий.
//
// Минимальные определения, которые ожидают примеры examples/.

#pragma once

// ── WiFi credentials по умолчанию ────────────────────────────────────────────
// Используются только при первом запуске, если в NVS ещё нет сохранённых
// credentials. После Improv-provisioning значения берутся из NVS.

#define WIFI_SSID      "your-ssid"
#define WIFI_PASSWORD  "your-password"

// ── Адрес provisioning API ───────────────────────────────────────────────────
// Передаётся в idryer::cloud::HttpApi. Можно определить здесь или через
// build_flags в platformio.ini (предпочтительный способ).

#ifndef IDRYER_API_BASE
#define IDRYER_API_BASE "https://portal.idryer.org/api"
#endif
